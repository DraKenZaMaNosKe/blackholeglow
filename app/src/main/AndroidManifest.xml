<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      ╔═══════════════════════════════════╗
      ║    ⚡️ PERMISO PARA VIBRAR ⚡️     ║
      ╚═══════════════════════════════════╝
      (~˘▾˘)~  📳 ¡Android Droid vibra!  📳  ~(^▾^)~
      Permiso necesario si en el código se invoca Vibrator.
    -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!--
      ╔═══════════════════════════════════════════════╗
      ║    🌐 PERMISOS PARA INTERNET Y RED 🌐         ║
      ╚═══════════════════════════════════════════════╝
      📡 INTERNET: Necesario para Google Sign-In y cargar avatar
      🔗 ACCESS_NETWORK_STATE: Verificar estado de la conexión
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!--
      ╔═══════════════════════════════════════════════╗
      ║    🎵 PERMISOS PARA VISUALIZACIÓN MUSICAL 🎵  ║
      ╚═══════════════════════════════════════════════╝
      🎼 RECORD_AUDIO: Permite capturar datos de audio para visualización
      🔊 MODIFY_AUDIO_SETTINGS: Permite acceder al Visualizer API

      ⚠️ IMPORTANTE: NO graba ni almacena audio, solo lee datos en tiempo real
      para crear efectos visuales sincronizados con la música.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>

    <!--
      ╔═══════════════════════════════════════════════╗
      ║    🖼️ PERMISO PARA CAMBIAR WALLPAPER 🖼️      ║
      ╚═══════════════════════════════════════════════╝
      Necesario para desinstalar el live wallpaper y restaurar
      un fondo estático cuando el usuario lo solicite.
    -->
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>

    <!--
      ╔═══════════════════════════════════════════════╗
      ║    👏 PERMISOS PARA ENCONTRAR CON APLAUSO 👏  ║
      ╚═══════════════════════════════════════════════╝
      DESHABILITADO - Funcionalidad removida para release
    -->
    <!-- COMENTADO: Permisos de servicio de aplausos deshabilitados
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    -->

    <!--
      ╔══════════════════════════════════════════════╗
      ║    🔔 PERMISO PARA NOTIFICACIONES 🔔         ║
      ╚══════════════════════════════════════════════╝
      Android 13+ requiere permiso explícito para mostrar notificaciones.
      Usado para informar al usuario sobre descargas y estado del wallpaper.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!--
      ╔══════════════════════════════════════════════╗
      ║     🚀 OPENGL ES 3.0 – PODER MÁXIMO 🚀      ║
      ╚══════════════════════════════════════════════╝
      OpenGL ES 3.0 para: Instancing, VAOs, GLSL 300 es
      Requiere Android 4.3+ (API 18+) - 95%+ dispositivos
    -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <!--
      ╔════════════════════════════════════════════════════════╗
      ║      🌌 CONFIGURACIÓN DE LA APLICACIÓN GALÁCTICA 🌌    ║
      ╚════════════════════════════════════════════════════════╝
      Icono, label, tema y reglas de backup.
      data_extraction_rules.xml y backup_rules.xml deben existir en res/xml.
    -->
    <application
        android:allowBackup="true"
        android:largeHeap="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.Blackholeglow"
        tools:targetApi="31">

        <!--
          ╔══════════════════════════════════════════════════════╗
          ║   💰 ADMOB - GOOGLE MOBILE ADS 💰                    ║
          ╚══════════════════════════════════════════════════════╝
          🧪 ID DE PRUEBA (para desarrollo)
          🚀 PRODUCCIÓN: Reemplazar con tu App ID real de AdMob

          Para obtener tu App ID:
          1. Ve a admob.google.com
          2. Agrega tu app
          3. Copia el App ID (formato: ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX)
        -->
        <!-- 🧪 TEST App ID - Cambiar a producción cuando la cuenta esté aprobada -->
        <!-- PROD: ca-app-pub-6734758230109098~7716587922 -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- Resolver conflicto entre Analytics y Ads SDK -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!--
          ╔════════════════════════════════════════╗
          ║ 🚀 SERVICIO LIVE WALLPAPER INVOCADO 🚀 ║
          ╚════════════════════════════════════════╝
          La clase LiveWallpaperService.java debe existir en com.secret.blackholeglow.
        -->
        <service
            android:name=".LiveWallpaperService"
            android:exported="true"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/live_wallpaper" />
        </service>

        <!--
          ╔════════════════════════════════════════════════════════╗
          ║   🔐 ACTIVITY: LOGIN CON GOOGLE 🔐                    ║
          ╚════════════════════════════════════════════════════════╝
          Pantalla de inicio de sesión con Google Sign-In
          Punto de entrada principal de la aplicación

          🎨 USA SPLASH THEME PARA INICIO PROFESIONAL:
          - Fondo oscuro con logo se ve INMEDIATAMENTE
          - NO más fondo blanco feo al inicio
        -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.Blackholeglow.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          ╔════════════════════════════════════════════════════════╗
          ║   🎆 ACTIVITY: SPLASH – LLAMADA INICIAL 🎆           ║
          ╚════════════════════════════════════════════════════════╝
          Ruta: app/src/main/java/com/secret/blackholeglow/activities/SplashActivity.java
        -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true" />

        <!--
          ╔══════════════════════════════════╗
          ║   🌠 ACTIVITY: PREVIEW ESTELAR 🌠 ║
          ╚══════════════════════════════════╝
          Ruta: app/src/main/java/com/secret/blackholeglow/activities/WallpaperPreviewActivity.java
        -->
        <activity
            android:name=".activities.WallpaperPreviewActivity"
            android:exported="true" />

        <!--
          ╔═══════════════════════════════════════════════════════════╗
          ║   ACTIVITY: PANTALLA DE CARGA CON PROGRESO               ║
          ╚═══════════════════════════════════════════════════════════╝
          Muestra barra de progreso mientras se precargan los recursos
          del wallpaper (texturas, shaders, modelos 3D)
        -->
        <activity
            android:name=".activities.WallpaperLoadingActivity"
            android:exported="true"
            android:theme="@style/Theme.Blackholeglow" />

        <!--
          ╔════════════════════════════════╗
          ║   🪐 ACTIVITY: MENÚ GALÁCTICO 🪐 ║
          ╚════════════════════════════════╝
          Ruta: app/src/main/java/com/secret/blackholeglow/activities/MainActivity.java
        -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true" />

        <!--
          ╔═══════════════════════════════════════════════╗
          ║   🤖 ACTIVITY: CHAT CON GEMINI AI 🤖          ║
          ╚═══════════════════════════════════════════════╝
          Chat flotante con Orbix (Gemini AI)
          Se muestra como overlay sobre el wallpaper
        -->
        <activity
            android:name=".activities.GeminiChatActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Blackholeglow.ChatOverlay" />

        <!--
          ╔═══════════════════════════════════════════╗
          ║   🎵 ACTIVITY: PERMISOS DE AUDIO 🎵       ║
          ╚═══════════════════════════════════════════╝
          Solicita el permiso RECORD_AUDIO en runtime
          Necesario para Android 6.0+ (API 23+)
        -->
        <activity
            android:name=".MusicPermissionActivity"
            android:exported="true"
            android:label="Permiso de Audio Musical"
            android:theme="@android:style/Theme.Material.Light.Dialog" />

        <!--
          ╔═══════════════════════════════════════════════════════════════╗
          ║   🌌 SERVICE: DAYDREAM (PROTECTOR DE PANTALLA) 🌌            ║
          ╚═══════════════════════════════════════════════════════════════╝
          🔋 Se activa automáticamente durante la carga del dispositivo
          ✨ Muestra el wallpaper animado como protector de pantalla

          📱 Configuración del usuario:
          Ajustes → Pantalla → Protector de pantalla → Black Hole Glow

          ⚡ Requiere permisos:
          - android.permission.BIND_DREAM_SERVICE (automático)

          🎨 Características:
          - OpenGL ES 2.0 con escenas 3D animadas
          - Pantalla completa inmersiva
          - Modo interactivo habilitado
          - Se activa durante carga o cuando el dispositivo está en reposo
        -->
        <service
            android:name=".GlowDreamService"
            android:exported="true"
            android:label="Black Hole Glow"
            android:permission="android.permission.BIND_DREAM_SERVICE">
            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.service.dream"
                android:resource="@xml/dream_glow" />
        </service>

        <!-- 🎵 LISTENER DE MÚSICA - Captura canciones en reproducción -->
        <service
            android:name=".sharing.MusicNotificationListener"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

    </application>
</manifest>
