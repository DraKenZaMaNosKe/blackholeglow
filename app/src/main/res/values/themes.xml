<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Día) -->
    <style name="Theme.Blackholeglow" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!--
      ╔════════════════════════════════════════════════════════════╗
      ║  🎨 SPLASH THEME - Tema profesional para pantalla inicial ║
      ║  Fondo oscuro con logo - SE VE INMEDIATAMENTE             ║
      ╚════════════════════════════════════════════════════════════╝
      Este tema se aplica ANTES de que la Activity cargue,
      eliminando el fondo blanco feo que Android muestra por defecto.
    -->
    <style name="Theme.Blackholeglow.Splash" parent="Theme.AppCompat.NoActionBar">
        <!-- Fondo negro con logo centrado (se ve INMEDIATAMENTE) -->
        <item name="android:windowBackground">@drawable/splash_background</item>

        <!-- Barra de estado negra (parte superior) -->
        <item name="android:statusBarColor">@android:color/black</item>

        <!-- Barra de navegación negra (parte inferior) -->
        <item name="android:navigationBarColor" tools:targetApi="o">@android:color/black</item>

        <!-- Sin action bar para pantalla completa -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Transición suave al cambiar de Activity -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Estilo para imágenes circulares (avatar) -->
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Estilo para Switch del detector de aplausos -->
    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#4CAF50</item> <!-- Verde cuando está ON -->
        <item name="colorSwitchThumbNormal">#FFFFFF</item> <!-- Blanco cuando está OFF -->
        <item name="android:colorForeground">#808080</item> <!-- Gris para fondo OFF -->
    </style>

    <!--
      ╔════════════════════════════════════════════════════════════╗
      ║  🤖 CHAT OVERLAY THEME - Tema para chat flotante Gemini   ║
      ║  Se muestra como diálogo transparente sobre el wallpaper  ║
      ╚════════════════════════════════════════════════════════════╝
    -->
    <style name="Theme.Blackholeglow.ChatOverlay" parent="Theme.AppCompat.Dialog">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
