<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_orbix_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diag_title"
            android:textColor="#00D4FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════════ -->
        <!-- TARJETA 1: DISPOSITIVO                     -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_diagnostic_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diag_device"
                android:textColor="#00D4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Modelo -->
            <TextView
                android:id="@+id/diag_device_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0B0B0"
                android:textSize="13sp" />

            <!-- Android version -->
            <TextView
                android:id="@+id/diag_android_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B0B0B0"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <!-- RAM tier badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diag_ram_tier"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/diag_ram_tier_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- RAM disponible (refresco en vivo) -->
            <TextView
                android:id="@+id/diag_ram_available"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E0E0E0"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <ProgressBar
                android:id="@+id/diag_ram_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="4dp"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <!-- Textura info -->
            <TextView
                android:id="@+id/diag_texture_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#808080"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!-- TARJETA 2: ALMACENAMIENTO                  -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_diagnostic_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diag_storage"
                android:textColor="#00D4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Total -->
            <TextView
                android:id="@+id/diag_storage_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Imagenes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖼️"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/diag_images_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/diag_images_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="8dp"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <!-- Videos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎬"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/diag_videos_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/diag_videos_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginBottom="8dp"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <!-- Modelos 3D -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧊"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/diag_models_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#B0B0B0"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/diag_models_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progressDrawable="@android:drawable/progress_horizontal" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!-- TARJETA 3: WALLPAPER ACTIVO                -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_diagnostic_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diag_active_wallpaper"
                android:textColor="#00D4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Nombre -->
            <TextView
                android:id="@+id/diag_active_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Peso + compat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/diag_active_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp" />

                <TextView
                    android:id="@+id/diag_active_compat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Mensaje descriptivo -->
            <TextView
                android:id="@+id/diag_active_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#808080"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!-- TARJETA 4: COMPATIBILIDAD                  -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_diagnostic_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/diag_compatibility"
                android:textColor="#00D4FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Leyenda -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Verde = Optimo -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#4CAF50" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diag_legend_optimal"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="12dp" />

                <!-- Amarillo = Aceptable -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#FFC107" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diag_legend_moderate"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="12dp" />

                <!-- Rojo = No recomendado -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="#F44336" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/diag_legend_not_recommended"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Lista de wallpapers -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/diag_compat_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
